# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: server-only admin workflows such as seed scripts or privileged imports.
# Never expose this in client code.
SUPABASE_SECRET_KEY=

# Optional fallback app URL. Runtime request origin is preferred for auth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
